{
    "version": 4,
    "configurePresets": [
        {
            "name": "desktop-tests",
            "displayName": "Desktop Tests",
            "description": "Native desktop build for unit testing hardware-independent libraries",
            "binaryDir": "${sourceDir}/build/desktop-tests",
            "cacheVariables": {
                "BUILD_FIRMWARE": "OFF",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "desktop-tests",
            "configurePreset": "desktop-tests"
        }
    ],
    "testPresets": [
        {
            "name": "desktop-tests",
            "configurePreset": "desktop-tests",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}